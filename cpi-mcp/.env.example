# SAP CPI tenant host (e.g. mytenant.cfapps.sap.hana.ondemand.com)
CPI_TENANT_HOST=your-tenant-host

# Preferred auth method (choose one)
# 1. Static bearer token
CPI_BEARER_TOKEN=eyJ...

# 2. Client-credentials flow (optional)
CPI_CLIENT_ID=your-client-id
CPI_CLIENT_SECRET=your-client-secret
CPI_TOKEN_URL=https://<tenant-host>/oauth/token

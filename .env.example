API_HOST=https://dummy-tenant.sap.com/api/v1
TOKEN_URL=https://dummy-tenant.authentication.sap.com
CLIENT_ID=dummy-client-id
CLIENT_SECRET=dummy-client-secret
RATE_LIMIT=5
MAX_CONCURRENT_DOWNLOADS=3

# LLM Configuration (NVIDIA NIM endpoints are recommended)
LLM_API_KEY=your_nvidia_or_openrouter_api_key
LLM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
MODEL_NAME=meta/llama-3.1-70b-instruct
REVIEW_WINDOW_HOURS=720

# Orchestrator Unattended Mode
MAX_FIXES_PER_CYCLE=2   # Max LLM fix-generation calls per --unattended cycle
STALE_FIX_DAYS=7        # Days before an unapplied fix or structural flag escalates to 🔴
